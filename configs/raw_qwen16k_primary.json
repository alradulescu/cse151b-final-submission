  "disable_thinking": false,
  "self_consistency_n": 1,
  "model_postprocess": false,
  "csv_handling": [
    "id,response CSV packaging",
    "row-order preservation",
    "whitespace-safe serialization"
  ],
  "inference_mode": "local Qwen model generation plus CSV serialization"
}
